SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

DB_NAME=familytree
DB_USER=devuser
DB_PASSWORD=devpassword
DB_HOST=localhost
DB_PORT=5432
# Neon и другие облачные Postgres требуют SSL — на free-тарифе Render добавьте DB_SSLMODE=require.
# Локально не нужен, дефолт 'prefer' работает и с обычным Postgres без SSL.
DB_SSLMODE=prefer
